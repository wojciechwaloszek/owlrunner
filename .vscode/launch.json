    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Electron Main Process",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron-forge",
            "windows": {
                "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron-forge.cmd"
            },
            "runtimeArgs": [
                "start"
            ],
            "console": "integratedTerminal"
        }
    ]
}